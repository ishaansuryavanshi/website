const buildState={cat:'—',color:'Neon Green',size:'$2 · XS',price:2,qty:1};
function buildCatFilter(){
  const el=document.getElementById('b-cats');
  CATEGORIES.filter(c=>c!=='All').forEach(c=>{
    const btn=document.createElement('button');btn.className='bopt';btn.textContent=c;
    btn.onclick=()=>{selectBuild('cat',c,btn);};
    el.appendChild(btn);
  });
}
function selectBuild(type,val,el,price){
  if(type==='cat'){buildState.cat=val;document.getElementById('b-cats').querySelectorAll('.bopt').forEach(b=>b.classList.remove('selected'));}
  else if(type==='color'){document.querySelectorAll('#builder .build-step:nth-child(2) .bopt').forEach(b=>b.classList.remove('selected'));}
  else if(type==='size'){document.querySelectorAll('#builder .build-step:nth-child(3) .bopt').forEach(b=>b.classList.remove('selected'));buildState.price=price||2;}
  el.classList.add('selected');buildState[type]=val;updateSummary();
}
function changeQty(d){buildState.qty=Math.max(1,Math.min(50,buildState.qty+d));document.getElementById('qtyDisplay').textContent=buildState.qty;updateSummary();}
function updateSummary(){
  const hasDiscount=buildState.qty>=5;
  const raw=buildState.price*buildState.qty;
  const discount=hasDiscount?Math.floor(raw*.15):0;
  const total=raw-discount;
  document.getElementById('s-cat').textContent=buildState.cat;
  document.getElementById('s-color').textContent=buildState.color;
  document.getElementById('s-size').textContent=buildState.size;
  document.getElementById('s-qty').textContent=buildState.qty+' item'+(buildState.qty>1?'s':'');
  document.getElementById('s-unit').textContent='$'+buildState.price+'.00';
  document.getElementById('s-total').textContent='$'+total;
  document.getElementById('discountBanner').style.display=hasDiscount?'block':'none';
  const dl=document.getElementById('s-discount-line');
  if(hasDiscount){dl.style.display='flex';document.getElementById('s-discount').textContent='-$'+discount+' (15% off)';}
  else{dl.style.display='none';}
}
function submitBuild(){
  if(buildState.cat==='—'){showToast('⚠️ Please select a category first!');return;}
  showToast('🚀 Order sent! Check your email — we\'ll confirm within 24hrs.');
  setTimeout(()=>document.getElementById('cta').scrollIntoView({behavior:'smooth'}),1500);
}

