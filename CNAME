function getFiltered(){return PRODUCTS.filter(p=>{const catOk=activeCat==='All'||p.cat===activeCat;const priceOk=activePrice==='All'||p.price===parseInt(activePrice.replace('$',''));return catOk&&priceOk;});}

function priceBadgeClass(price){return{2:'badge-2',4:'badge-4',6:'badge-6',8:'badge-8',10:'badge-10'}[price]||'badge-2';}
function sizeLabel(price){return{2:'XS',4:'S',6:'M',8:'L',10:'XL'}[price]||'S';}
function thumbGrad(price){return{2:'rgba(57,255,20,0.15)',4:'rgba(0,212,255,0.15)',6:'rgba(255,0,200,0.12)',8:'rgba(255,45,85,0.12)',10:'rgba(255,165,0,0.12)'}[price]||'rgba(57,255,20,0.12)';}

function renderGrid(){
  const filtered=getFiltered();
  const grid=document.getElementById('prodGrid');
  const count=document.getElementById('resultsCount');
  count.innerHTML=`Showing <span>${Math.min(visibleCount,filtered.length)}</span> of <span>${filtered.length}</span> designs`;
  grid.innerHTML=filtered.slice(0,visibleCount).map(p=>`
    <div class="pc" onclick="addToCart('${p.name.replace(/'/g,"\\'")}')">
      <div class="thumb">
        <div class="thumb-bg" style="background:${thumbGrad(p.price)};"></div>
        <div class="thumb-icon">${p.icon}</div>
        <div class="price-badge ${priceBadgeClass(p.price)}">$${p.price}</div>
        <div class="size-pip">${sizeLabel(p.price)}</div>
      </div>
      <div class="pbody">
        <div class="pname">${p.name}</div>
        <div class="ptag">${p.cat} · ${sizeLabel(p.price)}</div>
        <div class="pstars">${Array.from({length:5},(_,j)=>`<span class="pstar" style="${j<p.rating?'':'opacity:.2'}">★</span>`).join('')}<span class="prev-count">(${p.reviews})</span></div>
