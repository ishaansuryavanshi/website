<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LayerUp 3D — Printed for Life</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#050508;--surface:#0a0a10;--card:#0d0d15;
  --border:rgba(255,255,255,0.06);--border-hi:rgba(255,255,255,0.13);
  --green:#39ff14;--green-dim:rgba(57,255,20,0.10);--green-glow:rgba(57,255,20,0.30);
  --blue:#00d4ff;--blue-dim:rgba(0,212,255,0.10);--blue-glow:rgba(0,212,255,0.30);
  --red:#ff2d55;--red-dim:rgba(255,45,85,0.10);--red-glow:rgba(255,45,85,0.30);
  --pink:#ff00c8;--orange:#ffa500;--gold:#ffd700;
  --text:#f0f0f8;--muted:#606080;--subtle:#282838;
  --radius:14px;
  --font-display:'Bebas Neue',sans-serif;
  --font-body:'Rajdhani',sans-serif;
  --font-mono:'Share Tech Mono',monospace;
}
html{scroll-behavior:smooth;}
body{font-family:var(--font-body);background:var(--bg);color:var(--text);overflow-x:hidden;line-height:1.6;font-size:16px;}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.07) 2px,rgba(0,0,0,0.07) 4px);pointer-events:none;z-index:9999;}
.neon-g{color:var(--green);text-shadow:0 0 8px var(--green),0 0 24px var(--green-glow);}
.neon-b{color:var(--blue);text-shadow:0 0 8px var(--blue),0 0 24px var(--blue-glow);}
.neon-r{color:var(--red);text-shadow:0 0 8px var(--red),0 0 24px var(--red-glow);}

/*── NAV ──*/
nav{position:sticky;top:0;left:0;right:0;z-index:500;display:flex;align-items:center;justify-content:space-between;padding:0 2.5rem;height:60px;background:rgba(5,5,8,0.95);backdrop-filter:blur(20px);border-bottom:1px solid rgba(57,255,20,0.12);}
.logo{font-family:var(--font-display);font-size:1.8rem;letter-spacing:.1em;text-decoration:none;color:var(--text);}
.logo .accent{color:var(--green);text-shadow:0 0 12px var(--green);}
nav ul{display:flex;gap:1.8rem;list-style:none;align-items:center;}
nav a{color:var(--muted);text-decoration:none;font-family:var(--font-mono);font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;transition:color .2s;}
nav a:hover{color:var(--green);}
.nav-cta{background:var(--green)!important;color:#050508!important;padding:.4rem 1.2rem;border-radius:4px;font-weight:700!important;text-shadow:none!important;letter-spacing:.06em!important;box-shadow:0 0 18px var(--green-glow);}
.nav-cart{position:relative;cursor:pointer;background:rgba(57,255,20,.1);border:1px solid rgba(57,255,20,.3);border-radius:4px;padding:.4rem .9rem;color:var(--green);font-family:var(--font-mono);font-size:.75rem;display:flex;align-items:center;gap:.4rem;transition:all .2s;}
.nav-cart:hover{background:rgba(57,255,20,.15);}
.cart-badge{position:absolute;top:-6px;right:-6px;background:var(--red);color:#fff;border-radius:50%;width:18px;height:18px;display:flex;align-items:center;justify-content:center;font-size:.55rem;font-weight:700;box-shadow:0 0 8px var(--red);}

/*── HERO ──*/
.hero{min-height:90vh;display:flex;align-items:center;padding:4rem 2.5rem;position:relative;overflow:hidden;}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(57,255,20,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(57,255,20,0.04) 1px,transparent 1px);background-size:60px 60px;}
.particles{position:absolute;inset:0;overflow:hidden;pointer-events:none;}
.particle{position:absolute;width:2px;height:2px;border-radius:50%;animation:float linear infinite;}
@keyframes float{0%{transform:translateY(100vh) translateX(0);opacity:0;}10%{opacity:1;}90%{opacity:1;}100%{transform:translateY(-20px) translateX(var(--dx,0px));opacity:0;}}
.hero-inner{position:relative;max-width:1300px;margin:0 auto;width:100%;display:grid;grid-template-columns:1.1fr 0.9fr;gap:5rem;align-items:center;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:.6rem;background:rgba(57,255,20,0.08);border:1px solid rgba(57,255,20,0.25);color:var(--green);font-family:var(--font-mono);font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;padding:.35rem 1rem;border-radius:3px;margin-bottom:1.5rem;}
.blink{animation:blink .8s step-end infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0;}}
h1{font-family:var(--font-display);font-size:clamp(4rem,8vw,7rem);line-height:.92;letter-spacing:.02em;margin-bottom:1.5rem;}
h1 .line2{-webkit-text-stroke:1px rgba(57,255,20,0.7);color:transparent;}
.hero-sub{font-size:1.05rem;color:var(--muted);max-width:440px;margin-bottom:2rem;line-height:1.8;}
.btn-row{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:1.5rem;}
.btn{display:inline-flex;align-items:center;gap:.5rem;padding:.8rem 2rem;border-radius:4px;font-family:var(--font-mono);font-size:.82rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;cursor:pointer;border:none;transition:transform .2s,box-shadow .2s;}
.btn:hover{transform:translateY(-3px);}
.btn-green{background:var(--green);color:#050508;box-shadow:0 0 24px var(--green-glow);}
.btn-green:hover{box-shadow:0 0 40px var(--green-glow);}
.btn-outline{background:transparent;color:var(--green);border:1px solid rgba(57,255,20,0.45);}
.btn-outline:hover{background:rgba(57,255,20,0.06);}
.hero-trust{display:flex;gap:1.5rem;flex-wrap:wrap;}
.trust-pill{display:flex;align-items:center;gap:.4rem;font-family:var(--font-mono);font-size:.62rem;color:var(--muted);letter-spacing:.08em;}
.hero-visual{display:flex;align-items:center;justify-content:center;}
.printer-scene{width:300px;height:300px;position:relative;display:flex;align-items:center;justify-content:center;}
.orbit{position:absolute;border-radius:50%;border:1px solid;animation:orbit linear infinite;}
.o1{inset:0;border-color:rgba(57,255,20,.25);animation-duration:22s;}
.o2{inset:36px;border-color:rgba(0,212,255,.2);animation-duration:15s;animation-direction:reverse;}
.o3{inset:72px;border-color:rgba(255,45,85,.18);animation-duration:10s;}
@keyframes orbit{to{transform:rotate(360deg);}}
.orbit-dot{position:absolute;top:50%;left:0;width:8px;height:8px;border-radius:50%;transform:translateY(-50%) translateX(-4px);}
.d1{background:var(--green);box-shadow:0 0 12px var(--green);}
.d2{background:var(--blue);box-shadow:0 0 12px var(--blue);}
.d3{background:var(--red);box-shadow:0 0 12px var(--red);}
.printer-core{width:140px;height:140px;background:var(--card);border:1px solid rgba(57,255,20,0.3);border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem;box-shadow:0 0 40px rgba(57,255,20,0.12);z-index:2;position:relative;}
.printer-icon{font-size:2.8rem;}
.print-beam{width:2px;height:24px;background:linear-gradient(to bottom,var(--green),transparent);animation:beam .8s ease-in-out infinite alternate;box-shadow:0 0 8px var(--green);}
@keyframes beam{from{opacity:.4;transform:scaleY(.6);}to{opacity:1;transform:scaleY(1);}}
.print-label{font-family:var(--font-mono);font-size:.6rem;color:var(--green);letter-spacing:.15em;}

/*── STATS BAR ──*/
.statsbar{background:var(--surface);border-top:1px solid rgba(57,255,20,0.1);border-bottom:1px solid rgba(57,255,20,0.1);padding:1.5rem 2.5rem;}
.stats-inner{max-width:1300px;margin:0 auto;display:grid;grid-template-columns:repeat(5,1fr);}
.stat{text-align:center;padding:.8rem;}
.stat-num{font-family:var(--font-display);font-size:2.4rem;letter-spacing:.04em;line-height:1;}
.stat-label{font-family:var(--font-mono);font-size:.65rem;color:var(--muted);margin-top:.3rem;letter-spacing:.1em;text-transform:uppercase;}

/*── SECTIONS ──*/
.section-inner{max-width:1300px;margin:0 auto;}
.section-eye{font-family:var(--font-mono);font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:.6rem;}
.section-title{font-family:var(--font-display);font-size:clamp(2.2rem,4vw,3.5rem);letter-spacing:.03em;line-height:1;margin-bottom:.5rem;}
.section-sub{font-size:.95rem;color:var(--muted);margin-bottom:3rem;line-height:1.8;}

/*── TRUST BADGES ──*/
#trustbar{padding:3rem 2.5rem;background:var(--surface);border-bottom:1px solid var(--border);}
.trust-grid{max-width:1300px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;}
.trust-card{display:flex;flex-direction:column;align-items:center;text-align:center;padding:1.5rem;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);transition:border-color .25s,transform .25s;}
.trust-card:hover{transform:translateY(-4px);}
.trust-card:nth-child(1):hover{border-color:rgba(57,255,20,.3);}
.trust-card:nth-child(2):hover{border-color:rgba(0,212,255,.3);}
.trust-card:nth-child(3):hover{border-color:rgba(255,165,0,.3);}
.trust-card:nth-child(4):hover{border-color:rgba(255,45,85,.3);}
.trust-icon{font-size:2rem;margin-bottom:.8rem;}
.trust-title{font-family:var(--font-display);font-size:1.1rem;letter-spacing:.04em;margin-bottom:.4rem;}
.trust-desc{font-size:.78rem;color:var(--muted);line-height:1.6;}

/*── BESTSELLERS ──*/
#bestsellers{padding:6rem 2.5rem;position:relative;}
#bestsellers::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(57,255,20,0.04) 0%,transparent 70%);pointer-events:none;}
.bestseller-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:1.5rem;}
.bs-hero{background:var(--card);border:1px solid rgba(57,255,20,0.25);border-radius:var(--radius);overflow:hidden;display:flex;flex-direction:column;box-shadow:0 0 40px rgba(57,255,20,0.06);transition:transform .3s;}
.bs-hero:hover{transform:translateY(-6px);}
.bs-thumb{height:220px;display:flex;align-items:center;justify-content:center;position:relative;background:linear-gradient(135deg,rgba(57,255,20,0.12),rgba(57,255,20,0.03));}
.bs-thumb-icon{font-size:5rem;}
.bs-badge{position:absolute;top:1rem;left:1rem;background:var(--green);color:#050508;font-family:var(--font-mono);font-size:.6rem;font-weight:700;letter-spacing:.1em;padding:.3rem .8rem;border-radius:3px;}
.bs-body{padding:1.5rem;flex:1;display:flex;flex-direction:column;}
.bs-name{font-family:var(--font-display);font-size:1.8rem;letter-spacing:.04em;margin-bottom:.4rem;}
.bs-stars{display:flex;gap:2px;margin-bottom:.5rem;}
.bs-star{color:var(--gold);font-size:.85rem;}
.bs-review-count{font-family:var(--font-mono);font-size:.62rem;color:var(--muted);margin-left:.4rem;}
.bs-desc{font-size:.85rem;color:var(--muted);line-height:1.7;flex:1;margin-bottom:1.2rem;}
.bs-foot{display:flex;align-items:center;justify-content:space-between;}
.bs-price{font-family:var(--font-display);font-size:2rem;color:var(--green);text-shadow:0 0 12px var(--green-glow);}
.bs-order{padding:.5rem 1.4rem;background:var(--green-dim);border:1px solid rgba(57,255,20,.35);color:var(--green);border-radius:4px;font-family:var(--font-mono);font-size:.72rem;cursor:pointer;transition:all .2s;}
.bs-order:hover{background:var(--green);color:#050508;}
.bs-side{display:flex;flex-direction:column;gap:1.5rem;}
.bs-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;display:flex;transition:transform .25s,border-color .25s;flex:1;position:relative;}
.bs-card:hover{transform:translateY(-4px);border-color:rgba(0,212,255,.3);}
.bs-card-thumb{width:100px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:2.5rem;}
.bs-card-body{padding:1rem;flex:1;display:flex;flex-direction:column;justify-content:space-between;}
.bs-card-name{font-weight:700;font-size:.95rem;margin-bottom:.2rem;}
.bs-card-desc{font-size:.75rem;color:var(--muted);line-height:1.5;flex:1;margin-bottom:.6rem;}
.bs-card-foot{display:flex;align-items:center;justify-content:space-between;}
.bs-card-price{font-family:var(--font-display);font-size:1.4rem;color:var(--blue);text-shadow:0 0 10px var(--blue-glow);}
.bs-mini-btn{padding:.25rem .7rem;background:var(--blue-dim);border:1px solid rgba(0,212,255,.3);color:var(--blue);border-radius:3px;font-family:var(--font-mono);font-size:.6rem;cursor:pointer;transition:all .2s;}
.bs-mini-btn:hover{background:var(--blue);color:#050508;}

/*── BUNDLES ──*/
#bundles{padding:6rem 2.5rem;background:var(--surface);}
.bundle-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem;}
.bundle-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:2rem;position:relative;overflow:hidden;transition:transform .3s,border-color .3s;}
.bundle-card:hover{transform:translateY(-6px);}
.bundle-card.featured{border-color:rgba(255,165,0,.4);}
.bundle-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.bc1::before{background:var(--green);}
.bc2::before{background:var(--orange);}
.bc3::before{background:var(--red);}
.bundle-name{font-family:var(--font-display);font-size:1.6rem;letter-spacing:.04em;margin-bottom:.4rem;}
.bundle-badge{display:inline-block;background:rgba(255,165,0,.15);border:1px solid rgba(255,165,0,.4);color:var(--orange);font-family:var(--font-mono);font-size:.6rem;letter-spacing:.1em;padding:.2rem .6rem;border-radius:3px;margin-bottom:1rem;}
.bundle-items{list-style:none;margin-bottom:1.5rem;}
.bundle-items li{font-size:.85rem;color:var(--muted);padding:.35rem 0;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.5rem;}
.bundle-items li::before{content:'✓';color:var(--green);font-weight:700;}
.bundle-pricing{display:flex;align-items:baseline;gap:.8rem;margin-bottom:1rem;}
.bundle-price{font-family:var(--font-display);font-size:2.8rem;color:var(--green);text-shadow:0 0 12px var(--green-glow);}
.bundle-original{font-family:var(--font-display);font-size:1.4rem;color:var(--muted);text-decoration:line-through;}
.bundle-savings{font-family:var(--font-mono);font-size:.65rem;color:var(--orange);background:rgba(255,165,0,.1);border:1px solid rgba(255,165,0,.25);padding:.2rem .6rem;border-radius:3px;}
.bundle-cta{width:100%;padding:.75rem;background:transparent;border:1px solid rgba(57,255,20,.4);color:var(--green);border-radius:4px;font-family:var(--font-mono);font-size:.78rem;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;transition:all .25s;}
.bundle-cta:hover,.bundle-card.featured .bundle-cta{background:var(--green);color:#050508;}
.bundle-popular{position:absolute;top:1.5rem;right:1.5rem;background:var(--orange);color:#050508;font-family:var(--font-mono);font-size:.58rem;font-weight:700;letter-spacing:.1em;padding:.25rem .7rem;border-radius:3px;}

/*── PRICE GUIDE ──*/
#priceguide{padding:6rem 2.5rem;}
.tiers{display:grid;grid-template-columns:repeat(5,1fr);gap:1rem;margin-top:3rem;}
.tier{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem 1rem;text-align:center;position:relative;overflow:hidden;transition:transform .3s;cursor:pointer;}
.tier:hover{transform:translateY(-8px);}
.tier::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.t2::before{background:var(--green);}
.t4::before{background:var(--blue);}
.t6::before{background:var(--pink);}
.t8::before{background:var(--red);}
.t10::before{background:var(--orange);}
.tier-price{font-family:var(--font-display);font-size:3rem;line-height:1;margin-bottom:.5rem;}
.t2 .tier-price{color:var(--green);}
.t4 .tier-price{color:var(--blue);}
.t6 .tier-price{color:var(--pink);}
.t8 .tier-price{color:var(--red);}
.t10 .tier-price{color:var(--orange);}
.tier-size{font-family:var(--font-mono);font-size:.62rem;letter-spacing:.12em;color:var(--muted);margin-bottom:1rem;text-transform:uppercase;}
.tier-items{list-style:none;text-align:left;font-size:.78rem;color:var(--muted);line-height:2;}
.tier-items li::before{content:'→ ';}

/*── HOW IT'S PRINTED ──*/
#howit{padding:6rem 2.5rem;background:var(--surface);}
.steps-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:0;position:relative;}
.steps-grid::after{content:'';position:absolute;top:56px;left:10%;right:10%;height:1px;background:linear-gradient(90deg,var(--green),var(--blue),var(--pink),var(--red),var(--green));}
.step{position:relative;z-index:1;text-align:center;padding:0 1rem;}
.step-num{width:52px;height:52px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-family:var(--font-mono);font-size:.75rem;font-weight:700;border:2px solid;margin:0 auto 1.5rem;position:relative;background:var(--surface);}
.s1 .step-num{color:var(--green);border-color:var(--green);}
.s2 .step-num{color:var(--blue);border-color:var(--blue);}
.s3 .step-num{color:var(--pink);border-color:var(--pink);}
.s4 .step-num{color:var(--red);border-color:var(--red);}
.s5 .step-num{color:var(--green);border-color:var(--green);}
.step-emoji{font-size:1.4rem;margin-bottom:.7rem;}
.step-head{font-family:var(--font-display);font-size:1.15rem;letter-spacing:.05em;margin-bottom:.4rem;}
.step-desc{font-size:.78rem;color:var(--muted);line-height:1.7;}

/*── REVIEWS ──*/
#reviews{padding:6rem 2.5rem;background:var(--bg);}
.reviews-header{display:flex;align-items:center;gap:3rem;margin-bottom:3rem;flex-wrap:wrap;}
.reviews-aggregate{display:flex;flex-direction:column;align-items:center;padding:2rem;background:var(--card);border:1px solid rgba(255,215,0,.2);border-radius:var(--radius);min-width:180px;}
.agg-score{font-family:var(--font-display);font-size:5rem;line-height:1;color:var(--gold);}
.agg-stars{display:flex;gap:3px;margin:.3rem 0;}
.agg-star{color:var(--gold);font-size:1.1rem;}
.agg-count{font-family:var(--font-mono);font-size:.65rem;color:var(--muted);}
.reviews-bars{flex:1;}
.rbar-row{display:flex;align-items:center;gap:.8rem;margin-bottom:.5rem;}
.rbar-label{font-family:var(--font-mono);font-size:.65rem;color:var(--muted);width:50px;text-align:right;}
.rbar-track{flex:1;height:8px;background:rgba(255,255,255,.06);border-radius:4px;overflow:hidden;}
.rbar-fill{height:100%;background:var(--gold);border-radius:4px;}
.rbar-pct{font-family:var(--font-mono);font-size:.6rem;color:var(--muted);width:35px;}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;}
.review-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;transition:transform .25s;}
.review-card:hover{transform:translateY(-4px);}
.review-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:.8rem;}
.review-stars{display:flex;gap:3px;}
.star{color:var(--orange);font-size:.9rem;}
.verified{display:flex;align-items:center;gap:.3rem;font-family:var(--font-mono);font-size:.58rem;color:var(--green);background:rgba(57,255,20,.08);border:1px solid rgba(57,255,20,.2);padding:.15rem .5rem;border-radius:2px;}
.review-text{font-size:.87rem;color:var(--text);line-height:1.75;margin-bottom:1.2rem;opacity:.85;}
.review-author{display:flex;align-items:center;gap:.75rem;}
.review-avatar{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:1rem;border:1px solid;flex-shrink:0;}
.av-g{background:rgba(57,255,20,.1);color:var(--green);border-color:rgba(57,255,20,.3);}
.av-b{background:rgba(0,212,255,.1);color:var(--blue);border-color:rgba(0,212,255,.3);}
.av-r{background:rgba(255,45,85,.1);color:var(--red);border-color:rgba(255,45,85,.3);}
.av-o{background:rgba(255,165,0,.1);color:var(--orange);border-color:rgba(255,165,0,.3);}
.review-name{font-weight:700;font-size:.85rem;}
.review-meta{font-family:var(--font-mono);font-size:.58rem;color:var(--muted);margin-top:.1rem;}
.review-product{font-family:var(--font-mono);font-size:.6rem;color:var(--muted);margin-top:.4rem;}
.review-product span{color:var(--green);}

/*── COLORS ──*/
#colors{padding:6rem 2.5rem;background:var(--surface);}
.color-showcase{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;margin-top:3rem;}
.color-block{border-radius:var(--radius);overflow:hidden;border:1px solid var(--border);transition:transform .3s;}
.color-block:hover{transform:translateY(-8px);}
.cb-preview{height:180px;display:flex;align-items:center;justify-content:center;font-size:4rem;}
.cb-g{background:linear-gradient(135deg,#0a1a0a,#0d2a0d);}
.cb-b{background:linear-gradient(135deg,#030d1a,#051520);}
.cb-r{background:linear-gradient(135deg,#1a030a,#250510);}
.cb-k{background:linear-gradient(135deg,#0a0a0f,#14141e);}
.cb-info{padding:1.2rem 1.5rem;background:var(--card);border-top:1px solid var(--border);}
.cb-name{font-family:var(--font-display);font-size:1.4rem;letter-spacing:.06em;margin-bottom:.25rem;}
.cb-desc{font-size:.78rem;color:var(--muted);line-height:1.6;}
.cb-dot{width:14px;height:14px;border-radius:50%;display:inline-block;margin-right:.5rem;vertical-align:middle;}

/*── CATALOG ──*/
#catalog{padding:6rem 2.5rem;}
.filter-strip{display:flex;gap:.6rem;flex-wrap:wrap;margin-bottom:1.5rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border);}
.fchip{padding:.38rem 1rem;border-radius:3px;font-family:var(--font-mono);font-size:.7rem;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--muted);transition:all .2s;}
.fchip:hover,.fchip.active{border-color:var(--green);color:var(--green);background:rgba(57,255,20,0.07);}
.price-strip{display:flex;gap:.6rem;flex-wrap:wrap;margin-bottom:2rem;}
.pchip{padding:.3rem .8rem;border-radius:3px;font-family:var(--font-mono);font-size:.65rem;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--muted);transition:all .2s;}
.pchip:hover,.pchip.active{border-color:var(--blue);color:var(--blue);background:rgba(0,212,255,0.07);}
.results-count{font-family:var(--font-mono);font-size:.7rem;color:var(--muted);margin-bottom:1.5rem;}
.results-count span{color:var(--green);}
.prod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1rem;}
.pc{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;cursor:pointer;transition:transform .25s,border-color .25s;}
.pc:hover{transform:translateY(-6px);border-color:rgba(57,255,20,0.4);}
.thumb{height:155px;display:flex;align-items:center;justify-content:center;position:relative;border-bottom:1px solid var(--border);}
.thumb-bg{position:absolute;inset:0;opacity:.08;}
.thumb-icon{font-size:3.5rem;position:relative;z-index:1;}
.price-badge{position:absolute;top:.6rem;left:.6rem;font-family:var(--font-display);font-size:1.1rem;padding:.1rem .55rem;border-radius:3px;z-index:2;}
.badge-2{background:rgba(57,255,20,.15);color:var(--green);border:1px solid rgba(57,255,20,.35);}
.badge-4{background:rgba(0,212,255,.15);color:var(--blue);border:1px solid rgba(0,212,255,.35);}
.badge-6{background:rgba(255,0,200,.12);color:var(--pink);border:1px solid rgba(255,0,200,.35);}
.badge-8{background:rgba(255,45,85,.12);color:var(--red);border:1px solid rgba(255,45,85,.35);}
.badge-10{background:rgba(255,165,0,.12);color:#ffa500;border:1px solid rgba(255,165,0,.35);}
.size-pip{position:absolute;top:.6rem;right:.6rem;font-family:var(--font-mono);font-size:.58rem;padding:.2rem .5rem;border-radius:2px;border:1px solid var(--border);color:var(--muted);z-index:2;}
.pbody{padding:.9rem 1rem;}
.pname{font-weight:700;font-size:.95rem;margin-bottom:.22rem;}
.ptag{font-family:var(--font-mono);font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:.4rem;}
.pstars{display:flex;align-items:center;gap:2px;margin-bottom:.5rem;}
.pstar{color:var(--gold);font-size:.7rem;}
.prev-count{font-family:var(--font-mono);font-size:.58rem;color:var(--muted);margin-left:.3rem;}
.pdesc{font-size:.78rem;color:var(--muted);margin-bottom:.85rem;line-height:1.55;}
.pmeta{display:flex;align-items:center;justify-content:space-between;}
.pweight{font-family:var(--font-mono);font-size:.64rem;color:var(--subtle);}
.add-btn{padding:.28rem .75rem;background:var(--green-dim);border:1px solid rgba(57,255,20,.3);color:var(--green);border-radius:3px;font-family:var(--font-mono);font-size:.62rem;cursor:pointer;transition:all .2s;}
.add-btn:hover{background:var(--green);color:#050508;}
.load-more-wrap{text-align:center;margin-top:3rem;}
.load-more{padding:.75rem 2.5rem;background:transparent;border:1px solid rgba(57,255,20,.35);color:var(--green);border-radius:4px;font-family:var(--font-mono);font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:all .25s;}
.load-more:hover{background:rgba(57,255,20,0.08);}

/*── WHY ──*/
#why{padding:6rem 2.5rem;background:var(--surface);}
.why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem;}
.why-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:2rem;position:relative;overflow:hidden;transition:border-color .25s,transform .25s;}
.why-card:hover{transform:translateY(-4px);}
.why-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.wc1::before{background:linear-gradient(90deg,var(--green),transparent);}
.wc2::before{background:linear-gradient(90deg,var(--blue),transparent);}
.wc3::before{background:linear-gradient(90deg,var(--red),transparent);}
.wc4::before{background:linear-gradient(90deg,var(--pink),transparent);}
.wc5::before{background:linear-gradient(90deg,var(--orange),transparent);}
.wc6::before{background:linear-gradient(90deg,var(--green),transparent);}
.why-icon{font-size:2rem;margin-bottom:1rem;}
.why-head{font-family:var(--font-display);font-size:1.4rem;letter-spacing:.03em;margin-bottom:.5rem;}
.why-desc{font-size:.83rem;color:var(--muted);line-height:1.7;}

/*── FAQ ──*/
#faq{padding:6rem 2.5rem;}
.faq-list{max-width:780px;margin:3rem auto 0;}
.faq-item{border:1px solid var(--border);border-radius:var(--radius);margin-bottom:.8rem;overflow:hidden;transition:border-color .2s;}
.faq-item.open{border-color:rgba(57,255,20,.3);}
.faq-q{display:flex;align-items:center;justify-content:space-between;padding:1.2rem 1.5rem;cursor:pointer;font-size:.95rem;font-weight:600;gap:1rem;transition:background .2s;}
.faq-q:hover{background:rgba(57,255,20,.03);}
.faq-icon{font-family:var(--font-mono);font-size:1rem;color:var(--green);transition:transform .3s;flex-shrink:0;}
.faq-item.open .faq-icon{transform:rotate(45deg);}
.faq-a{max-height:0;overflow:hidden;transition:max-height .35s ease;}
.faq-a-inner{padding:0 1.5rem 1.2rem;font-size:.88rem;color:var(--muted);line-height:1.8;border-top:1px solid var(--border);}
.faq-item.open .faq-a{max-height:400px;}

/*── ORDER BUILDER ──*/
#builder{padding:6rem 2.5rem;background:var(--surface);}
.builder-wrap{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;margin-top:3rem;}
.build-step{margin-bottom:2rem;}
.build-label{font-family:var(--font-mono);font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:.8rem;display:flex;align-items:center;gap:.6rem;}
.build-label::after{content:'';flex:1;height:1px;background:var(--border);}
.build-options{display:flex;gap:.6rem;flex-wrap:wrap;}
.bopt{padding:.45rem 1rem;border-radius:4px;font-family:var(--font-mono);font-size:.72rem;letter-spacing:.08em;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;transition:all .2s;}
.bopt:hover{border-color:rgba(57,255,20,.4);color:var(--green);}
.bopt.selected{border-color:var(--green);color:var(--green);background:rgba(57,255,20,.08);}
.bopt-blue.selected{border-color:var(--blue);color:var(--blue);background:rgba(0,212,255,.1);}
.bopt-red.selected{border-color:var(--red);color:var(--red);background:rgba(255,45,85,.1);}
.bopt-black.selected{border-color:#aaa;color:#aaa;background:rgba(255,255,255,.05);}
.build-qty{display:flex;align-items:center;gap:1rem;}
.qty-btn{width:36px;height:36px;border-radius:4px;border:1px solid rgba(57,255,20,.3);background:transparent;color:var(--green);font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.qty-btn:hover{background:rgba(57,255,20,.1);}
.qty-display{font-family:var(--font-display);font-size:2rem;color:var(--text);min-width:40px;text-align:center;}
.build-summary{background:var(--card);border:1px solid rgba(57,255,20,.2);border-radius:var(--radius);padding:2rem;position:sticky;top:80px;}
.summary-title{font-family:var(--font-display);font-size:1.6rem;letter-spacing:.04em;margin-bottom:1.5rem;color:var(--green);}
.summary-line{display:flex;justify-content:space-between;align-items:center;padding:.6rem 0;border-bottom:1px solid var(--border);font-size:.85rem;}
.summary-key{color:var(--muted);font-family:var(--font-mono);font-size:.68rem;letter-spacing:.08em;}
.summary-val{font-weight:700;color:var(--text);}
.summary-discount{color:var(--green)!important;}
.summary-total{display:flex;justify-content:space-between;align-items:baseline;margin-top:1.5rem;padding-top:1.2rem;border-top:1px solid rgba(57,255,20,.2);}
.summary-total-label{font-family:var(--font-mono);font-size:.7rem;letter-spacing:.15em;color:var(--muted);text-transform:uppercase;}
.summary-total-price{font-family:var(--font-display);font-size:3rem;color:var(--green);}
.summary-cta{width:100%;margin-top:1.5rem;padding:1rem;background:var(--green);color:#050508;border:none;border-radius:4px;font-family:var(--font-mono);font-size:.85rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;box-shadow:0 0 24px var(--green-glow);transition:all .2s;}
.summary-cta:hover{box-shadow:0 0 40px var(--green-glow);transform:translateY(-2px);}
.summary-note{text-align:center;font-family:var(--font-mono);font-size:.6rem;color:var(--muted);margin-top:.8rem;letter-spacing:.06em;}
.discount-banner{background:rgba(57,255,20,.08);border:1px solid rgba(57,255,20,.25);border-radius:6px;padding:.6rem 1rem;margin-bottom:1.2rem;font-family:var(--font-mono);font-size:.68rem;color:var(--green);display:none;}

/*── CTA ──*/
#cta{padding:7rem 2.5rem;text-align:center;border-top:1px solid rgba(57,255,20,0.1);position:relative;}
#cta::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 80% at 50% 50%,rgba(57,255,20,0.05) 0%,transparent 70%);}
.cta-inner{position:relative;}
.cta-title{font-family:var(--font-display);font-size:clamp(3rem,6vw,5.5rem);letter-spacing:.03em;line-height:.95;margin-bottom:1.5rem;}
.cta-sub{font-size:1rem;color:var(--muted);margin-bottom:2.5rem;max-width:480px;margin-left:auto;margin-right:auto;}
.email-row{display:flex;gap:.8rem;max-width:480px;margin:0 auto 1.5rem;}
.email-input{flex:1;padding:.8rem 1.2rem;background:rgba(255,255,255,0.04);border:1px solid rgba(57,255,20,0.25);border-radius:4px;color:var(--text);font-family:var(--font-mono);font-size:.82rem;outline:none;transition:border-color .2s;}
.email-input:focus{border-color:var(--green);}
.email-input::placeholder{color:var(--muted);}
.cta-note{font-family:var(--font-mono);font-size:.65rem;color:var(--muted);letter-spacing:.08em;}

/*── FOOTER ──*/
footer{padding:3rem 2.5rem;border-top:1px solid var(--border);}
.footer-inner{max-width:1300px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;}
.footer-logo{font-family:var(--font-display);font-size:1.5rem;letter-spacing:.08em;}
.footer-logo .accent{color:var(--green);}
.footer-links{display:flex;gap:2rem;}
.footer-links a{font-family:var(--font-mono);font-size:.68rem;color:var(--muted);text-decoration:none;letter-spacing:.1em;text-transform:uppercase;transition:color .2s;}
.footer-links a:hover{color:var(--green);}
.footer-copy{font-family:var(--font-mono);font-size:.65rem;color:var(--subtle);}

/*── AI CHAT WIDGET ──*/
#chatWidget{position:fixed;bottom:2rem;right:2rem;z-index:450;}
.chat-toggle{width:56px;height:56px;border-radius:50%;background:var(--green);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.5rem;box-shadow:0 0 24px var(--green-glow);transition:transform .2s,box-shadow .2s;position:relative;}
.chat-toggle:hover{transform:scale(1.1);box-shadow:0 0 40px var(--green-glow);}
.chat-pulse{position:absolute;inset:0;border-radius:50%;border:2px solid var(--green);animation:chatPulse 2s ease-in-out infinite;}
@keyframes chatPulse{0%{transform:scale(1);opacity:1;}100%{transform:scale(1.6);opacity:0;}}
.chat-panel{position:absolute;bottom:70px;right:0;width:360px;background:var(--card);border:1px solid rgba(57,255,20,.25);border-radius:16px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.5),0 0 40px rgba(57,255,20,.08);display:none;flex-direction:column;max-height:520px;}
.chat-panel.open{display:flex;}
.chat-head{background:linear-gradient(135deg,rgba(57,255,20,.12),rgba(57,255,20,.04));padding:1rem 1.2rem;border-bottom:1px solid rgba(57,255,20,.15);display:flex;align-items:center;gap:.8rem;}
.chat-avatar{width:36px;height:36px;border-radius:50%;background:var(--green);display:flex;align-items:center;justify-content:center;font-size:1.1rem;}
.chat-info{flex:1;}
.chat-name{font-family:var(--font-display);font-size:1rem;letter-spacing:.04em;color:var(--green);}
.chat-status{font-family:var(--font-mono);font-size:.6rem;color:var(--muted);display:flex;align-items:center;gap:.3rem;}
.chat-online{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 1.5s infinite;}
@keyframes pulse{0%,100%{transform:scale(1);opacity:1;}50%{transform:scale(1.5);opacity:.6;}}
.chat-close{background:none;border:none;color:var(--muted);cursor:pointer;font-size:1.2rem;transition:color .2s;padding:.2rem;}
.chat-close:hover{color:var(--text);}
.chat-messages{flex:1;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:.8rem;min-height:200px;}
.chat-messages::-webkit-scrollbar{width:4px;}
.chat-messages::-webkit-scrollbar-thumb{background:rgba(57,255,20,.2);border-radius:2px;}
.chat-msg{max-width:85%;font-size:.82rem;line-height:1.6;padding:.7rem .9rem;border-radius:10px;}
.msg-ai{background:rgba(57,255,20,.08);border:1px solid rgba(57,255,20,.15);color:var(--text);align-self:flex-start;border-radius:10px 10px 10px 2px;}
.msg-user{background:rgba(0,212,255,.1);border:1px solid rgba(0,212,255,.2);color:var(--text);align-self:flex-end;border-radius:10px 10px 2px 10px;}
.msg-typing{display:flex;gap:4px;align-items:center;padding:.7rem .9rem;background:rgba(57,255,20,.06);border:1px solid rgba(57,255,20,.12);border-radius:10px 10px 10px 2px;align-self:flex-start;}
.typing-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:typingBounce 1.2s ease-in-out infinite;}
.typing-dot:nth-child(2){animation-delay:.2s;}
.typing-dot:nth-child(3){animation-delay:.4s;}
@keyframes typingBounce{0%,80%,100%{transform:translateY(0);}40%{transform:translateY(-8px);}}
.chat-quick{display:flex;gap:.4rem;flex-wrap:wrap;padding:.6rem 1rem;border-top:1px solid var(--border);}
.quick-btn{padding:.3rem .7rem;background:var(--green-dim);border:1px solid rgba(57,255,20,.25);color:var(--green);border-radius:12px;font-family:var(--font-mono);font-size:.6rem;cursor:pointer;transition:all .2s;white-space:nowrap;}
.quick-btn:hover{background:rgba(57,255,20,.15);}
.chat-input-row{display:flex;gap:.5rem;padding:.8rem 1rem;border-top:1px solid var(--border);}
.chat-input{flex:1;background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:8px;padding:.5rem .8rem;color:var(--text);font-family:var(--font-mono);font-size:.78rem;outline:none;transition:border-color .2s;}
.chat-input:focus{border-color:rgba(57,255,20,.35);}
.chat-input::placeholder{color:var(--muted);}
.chat-send{background:var(--green);border:none;border-radius:8px;width:36px;height:36px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1rem;transition:box-shadow .2s;}
.chat-send:hover{box-shadow:0 0 16px var(--green-glow);}
.chat-error{font-family:var(--font-mono);font-size:.65rem;color:var(--red);text-align:center;padding:.5rem 1rem;border-top:1px solid rgba(255,45,85,.15);}

/*── TOAST ──*/
.toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(150%);background:var(--card);border:1px solid rgba(57,255,20,0.4);border-radius:8px;padding:1rem 1.5rem;font-family:var(--font-mono);font-size:.78rem;color:var(--green);box-shadow:0 0 30px rgba(57,255,20,0.15);transition:transform .4s cubic-bezier(0.175,0.885,0.32,1.275);z-index:1000;white-space:nowrap;}
.toast.show{transform:translateX(-50%) translateY(0);}

/*── RESPONSIVE ──*/
@media(max-width:900px){
  .hero-inner{grid-template-columns:1fr;}
  .stats-inner{grid-template-columns:repeat(3,1fr);}
  .steps-grid{grid-template-columns:1fr 1fr;gap:2rem;}
  .steps-grid::after{display:none;}
  .color-showcase{grid-template-columns:1fr 1fr;}
  .why-grid{grid-template-columns:1fr 1fr;}
  .bestseller-grid{grid-template-columns:1fr;}
  .tiers{grid-template-columns:1fr 1fr;}
  .reviews-grid{grid-template-columns:1fr 1fr;}
  .builder-wrap{grid-template-columns:1fr;}
  .bundle-grid{grid-template-columns:1fr;}
  .trust-grid{grid-template-columns:1fr 1fr;}
  .chat-panel{width:300px;}
}
@media(max-width:600px){
  nav ul{display:none;}
  .stats-inner{grid-template-columns:repeat(2,1fr);}
  .color-showcase{grid-template-columns:1fr;}
  .why-grid{grid-template-columns:1fr;}
  .email-row{flex-direction:column;}
  .tiers{grid-template-columns:1fr;}
  .reviews-grid{grid-template-columns:1fr;}
  .trust-grid{grid-template-columns:1fr;}
  .reviews-header{flex-direction:column;}
}
</style>
</head>
